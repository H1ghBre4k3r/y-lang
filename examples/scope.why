declare print : (str) -> void
declare printi : (int) -> void

let bar := (foo : str) : void => {
    print(foo)
    print(" ")
}

let foo := 42

if 3 > 2 {
    bar("foo")
    printi(foo)
    print(" ")
    let foo := 13
    printi(foo)
    print(" ")
}

if 3 < 2 {
    printi(foo)
    print(" ")
    let foo := 13
    printi(foo)
    print(" ")
} else {
    bar("foo")
    printi(foo)
    print(" ")
    let foo := 13
    printi(foo)
    print(" ")
}

{
    bar("foo")
    printi(foo)
    print(" ")
    let foo := 13
    printi(foo)
    print(" ")
}

bar("foo")

let test := () : void => {
    bar("foo")
    let foo := 13
    printi(foo)
    print(" ")
}

test()

let x := {
    bar("foo")
    printi(foo)
    print(" ")
    let foo := 13
    printi(foo)
    print(" ")
    foo
}

printi(x)
print(" ")

printi(foo)
