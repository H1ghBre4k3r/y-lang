declare print : (str) -> void
declare printi : (int) -> void

let a := 456

let b := true

let c := 123

printi(a)

printi(c)

let d := true

let foo := () : void => {
    print(" From Function ")
}

let e := true 

let bar := foo

let some_function := (x : bool) : int => {
    if x {
        4 
    } else {
        7
    }
}

foo()
bar()

printi(some_function(true))
