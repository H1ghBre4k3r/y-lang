
let foo := ( bar : (int, int) -> int ): int => {
    bar(3, 4)
}

let test := (x : int, y : int) : int => {
    x + y
}

printi(foo(test))

let a := 3

let nested := (offset : int, func: ( (int, int) -> int ) -> int) : int => {
    func(test) + offset 
}

print(" ")

printi(nested(a, foo))

print(" ")
printi(nested(7, (inner : (int, int) -> int): int => { inner(41, 17) }))
